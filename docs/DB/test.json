# 트렌드 카테고리
type Categories {
  # 카테고리 ID 일련번호
  categoryId: ID!
  # 카테고리명
  categoryName: String!
  # 분류 단계
  depth: String!
  # 화면 노출 순서
  sortOrder: Int!
  # 사용 여부
  isActive: Int!
  # 트렌드 카테고리
  categories: Categories
  # 트렌드 카테고리
  categoriesList: [Categories!]!
  # 검색 기록
  searchLogsList: [SearchLogs!]!
  # 트렌드-카테고리 매핑 테이블
  trendCategoryMapList: [TrendCategoryMap!]!
  # 유저 선호 카테고리
  userInterestCategoriesList: [UserInterestCategories!]!
  # 유저 선호 키워드
  userInterestKeywordsList: [UserInterestKeywords!]!
}

# OAuth 계정 연동
type OauthAccounts {
  # OAuth 계정 ID 일련번호
  oauthId: ID!
  # 정보 제공자
  provider: String!
  # 외부 서비스 사용자 식별값
  providerUserId: String!
  # OAuth 이메일
  email: String!
  # 연동일
  createdAt: String!
  # 유저
  users: Users
}

# 검색 기록
type SearchLogs {
  # 검색 기록 ID
  searchLogId: ID!
  # 검색어
  keyword: String!
  # 검색 결과 수
  resultCount: Int!
  # 검색 시각
  searchedAt: String!
  # 최근 검색어 삭제 여부
  isDeleted: Int!
  # 유저
  users: Users
  # 트렌드 카테고리
  categories: Categories
}

# 트렌드 AI 분석
type TrendAiAnalyses {
  # AI 분석 ID
  analysisId: ID!
  # AI 한줄 요약
  oneLineSummary: String!
  # 유행 이유 설명
  reasonText: String!
  # 상세 설명
  detailText: String
  # 사용 AI 모델명
  modelName: String!
  # 분석 생성일
  createdAt: String!
  # 트렌드 정보
  trends: Trends
}

# 트렌드-카테고리 매핑 테이블
type TrendCategoryMap {
  # 매핑 PK
  trendCategoryId: ID!
  # 대표 카테고리 여부
  isPrimary: Int!
  # 트렌드 카테고리
  categories: Categories
  # 트렌드 정보
  trends: Trends
}

# 트랜드 랭크 스냅샷
type TrendRankSnapshots {
  # 순위 기록 ID
  rankSnapshotId: ID!
  # 순위 기준 플랫폼
  platform: String!
  # 현재 순위
  ranking: Int!
  # 바뀐 순위
  rankChange: String!
  # 트렌드 점수
  score: Int!
  # 수집 날짜
  collectedDate: String!
  # 수집 시각
  collectedAt: String!
  # 트렌드 정보
  trends: Trends
}

# 관련 키워드
type TrendRelatedKeywords {
  # 관련 키워드 ID
  relatedKeywordId: ID!
  # 키워드 이름
  keyword: String!
  # 관련 요소 타입
  relationType: String!
  # 표시 순서
  sortOrder: Int
  # 트렌드 정보
  trends: Trends
}

# 트렌드 출처 소스
type TrendSources {
  # 출처 ID
  sourceId: ID!
  # 원문 또는 수집 URL
  sourceUrl: String!
  # 플랫폼
  platform: String!
  # 수집 시각
  collectedAt: String!
  # 트렌드 정보
  trends: Trends
}

# 트렌드 정보
type Trends {
  # 트렌드 정보 ID
  trendId: ID!
  # 트렌드명 or 대표 키워드
  title: String!
  # 기본 요약
  summary: String!
  # 대표 이미지 URL
  thumbnailUrl: String
  # 조회 가능 상태
  status: String!
  # 최초 수집일
  firstCollectedAt: String!
  # 수정일
  updatedAt: String
  # 트렌드 AI 분석
  trendAiAnalysesList: [TrendAiAnalyses!]!
  # 트렌드-카테고리 매핑 테이블
  trendCategoryMapList: [TrendCategoryMap!]!
  # 트랜드 랭크 스냅샷
  trendRankSnapshotsList: [TrendRankSnapshots!]!
  # 트렌드 출처 소스
  trendSourcesList: [TrendSources!]!
  # 북마크 트렌드
  userTrendBookmarksList: [UserTrendBookmarks!]!
  # 관련 키워드
  trendRelatedKeywordsList: [TrendRelatedKeywords!]!
}

# 유저 선호 카테고리
type UserInterestCategories {
  # 사용자 관심사 ID
  userInterestId: ID!
  # 관심도 가중치
  weight: Int!
  # 선택일
  createdAt: String!
  # 유저
  users: Users
  # 트렌드 카테고리
  categories: Categories
}

# 유저 선호 키워드
type UserInterestKeywords {
  # 관심 키워드 ID
  interestKeywordId: ID!
  # 사용자 추가 관심 키워드
  keyword: String!
  # 추천 가중치
  weight: Int!
  # 등록일
  createdAt: String!
  # 유저
  users: Users
  # 트렌드 카테고리
  categories: Categories
}

# 유저 프로필
type UserProfiles {
  # 프로필 ID 일련번호
  profileId: ID!
  # 화면 표시용 닉네임
  nickname: String!
  # 프로필 이미지 경로
  profileImageUrl: String
  # 수정일
  updatedAt: String
  # 유저
  users: Users
}

# 북마크 트렌드
type UserTrendBookmarks {
  # 저장 ID
  bookmarkId: ID!
  # 저장일
  createdAt: String!
  # 트렌드 정보
  trends: Trends
  # 유저
  users: Users
}

# 유저
type Users {
  # 사용자 ID 일련번호
  userId: ID!
  # 로그인 ID
  loginId: String!
  # 비밀번호 해시값
  passwordHash: String!
  # 사용자 이름
  name: String!
  # 이메일 & OAuth 연동
  email: String
  # 계정 상태
  status: String!
  # 가입일
  createdAt: String!
  # 수정일
  updatedAt: String
  # OAuth 계정 연동
  oauthAccountsList: [OauthAccounts!]!
  # 검색 기록
  searchLogsList: [SearchLogs!]!
  # 유저 선호 카테고리
  userInterestCategoriesList: [UserInterestCategories!]!
  # 유저 선호 키워드
  userInterestKeywordsList: [UserInterestKeywords!]!
  # 유저 프로필
  userProfilesList: [UserProfiles!]!
  # 북마크 트렌드
  userTrendBookmarksList: [UserTrendBookmarks!]!
}